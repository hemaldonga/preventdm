# =============================================================================
# PreventDM — Compose-Level Environment Configuration Template
# =============================================================================
#
# This file documents every environment variable referenced in
# docker-compose.yml. It is a TEMPLATE ONLY — it is NOT sourced automatically
# and is safe to commit to source control.
#
# HOW TO USE
#   1. Copy this file:
#        cp .env.example.compose .env
#   2. Edit .env with your values (never commit .env).
#   3. Docker Compose reads .env automatically. To use a custom filename:
#        docker compose --env-file .env.compose up -d
#
# SECURITY WARNING
#   The default PostgreSQL credentials below exist for local development
#   convenience only. Production deployments MUST override POSTGRES_USER,
#   POSTGRES_PASSWORD, and POSTGRES_DB with strong, unique values injected
#   via a secrets manager or CI/CD secrets injection — never via a committed
#   file.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Host port mappings
#
# Override these if the default ports conflict with other services already
# running on your machine. Only the host-side port changes; the container-side
# port is fixed by the service code and Dockerfile and cannot be overridden
# here without also modifying those files.
# -----------------------------------------------------------------------------

# Host port → FastAPI backend container port 8000.
BACKEND_PORT=8000

# Host port → Rust Axum validation service container port 8001.
RUST_SERVICE_PORT=8001

# Host port → Python ML inference service container port 8002.
ML_SERVICE_PORT=8002

# Host port → PostgreSQL container port 5432.
POSTGRES_PORT=5432

# Host port → Redis container port 6379.
REDIS_PORT=6379


# -----------------------------------------------------------------------------
# PostgreSQL credentials
#
# These values are used in three places:
#   1. The postgres container initialises the database user and database name
#      from POSTGRES_USER and POSTGRES_DB on first startup.
#   2. DATABASE_URL is constructed from all three and injected into every
#      application container so Phase Nine can connect without extra config.
#   3. The pg_isready health check confirms the server is ready; the -d flag
#      verifies the target database has been created.
#
# PRODUCTION NOTE
#   - Use a randomly generated password of at least 32 characters.
#   - The password must not contain URL-reserved characters (@ : / ? # [ ])
#     unless you percent-encode them, because it is embedded verbatim in the
#     DATABASE_URL connection string.
#   - Rotate credentials independently of application deployments.
# -----------------------------------------------------------------------------

# PostgreSQL application role. The postgres image creates this role on first
# startup. This is distinct from the built-in postgres superuser.
POSTGRES_USER=preventdm

# Password for POSTGRES_USER. Change this before any shared or cloud deployment.
POSTGRES_PASSWORD=preventdm_dev_password

# Name of the application database. The postgres image creates this database
# and grants ownership to POSTGRES_USER on first startup.
POSTGRES_DB=preventdm


# -----------------------------------------------------------------------------
# Application environment
#
# Passed to all three application services as the APP_ENV environment variable.
# Controls logging verbosity and any environment-gated behaviour in service
# code. All three services validate this value at startup.
#
# Valid values: development | staging | production
# -----------------------------------------------------------------------------

APP_ENV=development
