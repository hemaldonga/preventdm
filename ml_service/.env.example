# APP_NAME: Display name returned in API health responses and OpenAPI documentation title.
APP_NAME=PreventDM ML Service

# APP_ENV: Runtime environment. Valid values: development, staging, production.
APP_ENV=development

# LOG_LEVEL: Logging verbosity sent to stdout. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# PORT: TCP port the service listens on. Defaults to 8002 to avoid colliding with the
# Python FastAPI backend on port 8000 and the Rust validation service on port 8001.
PORT=8002
