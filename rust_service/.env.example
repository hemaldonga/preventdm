# APP_NAME: Display name returned in API health responses.
APP_NAME=PreventDM Validation Service

# APP_ENV: Runtime environment. Valid values: development, staging, production.
APP_ENV=development

# LOG_LEVEL: Logging verbosity sent to stdout. Valid values: trace, debug, info, warn, error.
LOG_LEVEL=info

# SERVER_PORT: TCP port the service listens on. Defaults to 8001 to avoid
# colliding with the Python FastAPI backend which runs on port 8000.
SERVER_PORT=8001
